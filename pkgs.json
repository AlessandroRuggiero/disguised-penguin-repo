{
    "bash": {
        "container": "bash:latest",
        "configmounts": {
            "bashuser": "/root/"
        }
    },
    "claude": {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/claude:main",
        "configmounts": {
            "dotclaude": "/home/penguin/.claude/"
        }
    },
    "firebase": 
    {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/firebase:main",
        "configmounts": {
            "config": "/home/penguin/.config/"
        },
        "portmappings": {
            "9005": "9005"
        }
    },
    "opencode": {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/opencode:main",
        "configmounts": {
            "opencodeconfig": "/home/penguin/.local/share/opencode/"
        }
    },
    "gcloud": {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/gcloud:main",
        "configmounts": {
            "gcloudconfig": "/home/penguin/.config/gcloud/"
        }
    },
    "doctl": {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/doctl:main",
        "configmounts": {
            "doctlconfig": "/home/penguin/.config/doctl/"
        }
    },
    "gemini": {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/gemini:main",
        "configmounts": {
            "geminiconfig": "/home/penguin/.gemini/"
        }
    }
}