{
    "bash": {
        "container": "bash:latest",
        "configmounts": {
            "bashuser": "/root/"
        }
    },
    "claude": {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/claude:main",
        "configmounts": {
            "dotclaude": "/home/claude/.claude/"
        }
    },
    "firebase": 
    {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/firebase:main",
        "configmounts": {
            "config": "/root/.config/"
        },
        "portmappings": {
            "9005": "9005"
        }
    },
    "opencode": {
        "container": "ghcr.io/alessandroruggiero/disguised-penguin-repo/opencode:main",
        "configmounts": {
            "opencodeconfig": "/root/.local/share/opencode/"
        }
    }
}